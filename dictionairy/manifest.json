{

	"manifest_version":3, 
	"name":"Dictionary", 
	"version":"1.0",
	"description":"Double click on any word to see it's definition", 
	"permissions":[], 
	"host_permissions":[
		    "https://api.dictionaryapi.dev/*"

	], 
	"content_scripts":[
		{
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
	]

}
